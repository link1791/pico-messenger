generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Message {
  id        String   @id @default(cuid())
  fromUser  String
  toUser    String
  text      String
  createdAt DateTime @default(now())

  @@index([toUser, fromUser])
}

model Contact {
  id        String   @id @default(cuid())
  username  String   @unique
  createdAt DateTime @default(now())
}